{
  "name": "Node.js & TypeScript",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "customizations": {
    "vscode": {
      "extensions": ["oven.bun-vscode"]
    }
  },
  "postCreateCommand": "chmod +x .devcontainer/setup.sh && bun install --frozen-lockfile && .devcontainer/setup.sh",
  "remoteUser": "node"
}
