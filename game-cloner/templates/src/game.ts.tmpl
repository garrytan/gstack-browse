  // ─── Input: menu / meta controls ─────────────────────────────────────────

  private handleMenuInput(): void {
    // Space or Enter to start / restart
    if (this.input.wasJustPressed('Space') || this.input.wasJustPressed('Enter')) {
      if (this.state === 'idle' || this.state === 'gameover' || this.state === 'win') {
        this.start();
        return;
      }
    }
    // Escape to pause / unpause
    if (this.input.wasJustPressed('Escape')) {
      if (this.state === 'playing') this.state = 'paused';
      else if (this.state === 'paused') this.state = 'playing';
    }
  }

