#!/usr/bin/env bash
# gstack-session-cleanup — remove stale session tracking files.
#
# Usage: gstack-session-cleanup [directory]
#   directory: session directory (default: ~/.gstack/sessions)
#
# Removes files older than 120 minutes. Called by the preamble via script
# (not inline) so that damage-control hooks don't flag the find+rm pattern
# in the bash command text.
set -euo pipefail

SESSION_DIR="${1:-$HOME/.gstack/sessions}"
[ -d "$SESSION_DIR" ] || exit 0
find "$SESSION_DIR" -mmin +120 -type f -exec rm {} + 2>/dev/null || true
