#!/usr/bin/env bash
# cavestack-settings-hook — add/remove hooks in Claude Code settings.json
#
# Usage:
#   cavestack-settings-hook add <hook-command>      # add SessionStart hook
#   cavestack-settings-hook remove <hook-command>   # remove SessionStart hook
#   cavestack-settings-hook install-caveman         # register caveman SessionStart + UserPromptSubmit hooks
#   cavestack-settings-hook remove-caveman          # remove caveman hooks
#
# Requires: bun (already a cavestack hard dependency)
# Writes atomically: .tmp + rename to prevent corruption on crash/disk-full.
# Creates settings.json.backup before destructive operations.

set -euo pipefail

ACTION="${1:-}"
HOOK_CMD="${2:-}"
SETTINGS_FILE="${CAVESTACK_SETTINGS_FILE:-$HOME/.claude/settings.json}"

if [ -z "$ACTION" ]; then
  echo "Usage: cavestack-settings-hook {add|remove|install-caveman|remove-caveman} [hook-command]" >&2
  exit 1
fi

if [ "$ACTION" = "add" ] || [ "$ACTION" = "remove" ]; then
  if [ -z "$HOOK_CMD" ]; then
    echo "Usage: cavestack-settings-hook $ACTION <hook-command>" >&2
    exit 1
  fi
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  exit 1
fi

case "$ACTION" in
  add)
    CAVESTACK_SETTINGS_PATH="$SETTINGS_FILE" CAVESTACK_HOOK_CMD="$HOOK_CMD" bun -e "
      const fs = require('fs');
      const settingsPath = process.env.CAVESTACK_SETTINGS_PATH;
      const hookCmd = process.env.CAVESTACK_HOOK_CMD;

      let settings = {};
      try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch {}

      if (!settings.hooks) settings.hooks = {};
      if (!settings.hooks.SessionStart) settings.hooks.SessionStart = [];

      // Dedup: check if hook command already registered
      const exists = settings.hooks.SessionStart.some(entry =>
        entry.hooks && entry.hooks.some(h => h.command && h.command.includes('cavestack-session-update'))
      );

      if (!exists) {
        settings.hooks.SessionStart.push({
          hooks: [{ type: 'command', command: hookCmd }]
        });
      }

      const tmp = settingsPath + '.tmp';
      fs.writeFileSync(tmp, JSON.stringify(settings, null, 2) + '\n');
      fs.renameSync(tmp, settingsPath);
    " 2>/dev/null
    ;;
  remove)
    [ -f "$SETTINGS_FILE" ] || exit 0
    CAVESTACK_SETTINGS_PATH="$SETTINGS_FILE" bun -e "
      const fs = require('fs');
      const settingsPath = process.env.CAVESTACK_SETTINGS_PATH;

      let settings = {};
      try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch { process.exit(0); }

      if (settings.hooks && settings.hooks.SessionStart) {
        settings.hooks.SessionStart = settings.hooks.SessionStart.filter(entry =>
          !(entry.hooks && entry.hooks.some(h => h.command && h.command.includes('cavestack-session-update')))
        );
        if (settings.hooks.SessionStart.length === 0) delete settings.hooks.SessionStart;
        if (Object.keys(settings.hooks).length === 0) delete settings.hooks;
      }

      const tmp = settingsPath + '.tmp';
      fs.writeFileSync(tmp, JSON.stringify(settings, null, 2) + '\n');
      fs.renameSync(tmp, settingsPath);
    " 2>/dev/null
    ;;
  install-caveman)
    CAVESTACK_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
    ACTIVATE_HOOK="node \"$CAVESTACK_ROOT/hooks/caveman-activate.js\""
    TRACKER_HOOK="node \"$CAVESTACK_ROOT/hooks/caveman-mode-tracker.js\""

    if ! command -v node >/dev/null 2>&1; then
      echo "Warning: node is not installed — caveman hooks require Node.js." >&2
      echo "Install Node.js (https://nodejs.org/) then re-run: $(basename "$0") install-caveman" >&2
      exit 0
    fi

    mkdir -p "$(dirname "$SETTINGS_FILE")"
    [ -f "$SETTINGS_FILE" ] && cp "$SETTINGS_FILE" "${SETTINGS_FILE}.backup"

    CAVESTACK_SETTINGS_PATH="$SETTINGS_FILE" CAVESTACK_ACTIVATE="$ACTIVATE_HOOK" CAVESTACK_TRACKER="$TRACKER_HOOK" bun -e "
      const fs = require('fs');
      const path = require('path');
      const settingsPath = process.env.CAVESTACK_SETTINGS_PATH;
      const activateCmd = process.env.CAVESTACK_ACTIVATE;
      const trackerCmd = process.env.CAVESTACK_TRACKER;

      let settings = {};
      try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch {}

      if (!settings.hooks) settings.hooks = {};

      // SessionStart: caveman-activate
      if (!settings.hooks.SessionStart) settings.hooks.SessionStart = [];
      const activateExists = settings.hooks.SessionStart.some(entry =>
        entry.hooks && entry.hooks.some(h => h.command && h.command.includes('caveman-activate'))
      );
      if (!activateExists) {
        settings.hooks.SessionStart.push({
          hooks: [{ type: 'command', command: activateCmd, timeout: 5, statusMessage: 'Loading cavestack caveman mode...' }]
        });
      }

      // UserPromptSubmit: caveman-mode-tracker
      if (!settings.hooks.UserPromptSubmit) settings.hooks.UserPromptSubmit = [];
      const trackerExists = settings.hooks.UserPromptSubmit.some(entry =>
        entry.hooks && entry.hooks.some(h => h.command && h.command.includes('caveman-mode-tracker'))
      );
      if (!trackerExists) {
        settings.hooks.UserPromptSubmit.push({
          hooks: [{ type: 'command', command: trackerCmd, timeout: 5 }]
        });
      }

      fs.mkdirSync(path.dirname(settingsPath), { recursive: true });
      const tmp = settingsPath + '.tmp';
      fs.writeFileSync(tmp, JSON.stringify(settings, null, 2) + '\n');
      fs.renameSync(tmp, settingsPath);
    " 2>/dev/null
    ;;
  remove-caveman)
    [ -f "$SETTINGS_FILE" ] || exit 0
    cp "$SETTINGS_FILE" "${SETTINGS_FILE}.backup"
    CAVESTACK_SETTINGS_PATH="$SETTINGS_FILE" bun -e "
      const fs = require('fs');
      const settingsPath = process.env.CAVESTACK_SETTINGS_PATH;

      let settings = {};
      try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch { process.exit(0); }

      const drop = (arr, needle) => arr.filter(entry =>
        !(entry.hooks && entry.hooks.some(h => h.command && h.command.includes(needle)))
      );

      if (settings.hooks) {
        if (settings.hooks.SessionStart) {
          settings.hooks.SessionStart = drop(settings.hooks.SessionStart, 'caveman-activate');
          if (settings.hooks.SessionStart.length === 0) delete settings.hooks.SessionStart;
        }
        if (settings.hooks.UserPromptSubmit) {
          settings.hooks.UserPromptSubmit = drop(settings.hooks.UserPromptSubmit, 'caveman-mode-tracker');
          if (settings.hooks.UserPromptSubmit.length === 0) delete settings.hooks.UserPromptSubmit;
        }
        if (Object.keys(settings.hooks).length === 0) delete settings.hooks;
      }

      const tmp = settingsPath + '.tmp';
      fs.writeFileSync(tmp, JSON.stringify(settings, null, 2) + '\n');
      fs.renameSync(tmp, settingsPath);
    " 2>/dev/null
    ;;
  *)
    echo "Unknown action: $ACTION (expected add, remove, install-caveman, or remove-caveman)" >&2
    exit 1
    ;;
esac
