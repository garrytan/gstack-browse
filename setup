#!/usr/bin/env bash
# cavestack setup — build browser binary + register skills with Claude Code / Codex
set -e
umask 077  # Restrict new files to owner-only (0o600 files, 0o700 dirs)

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

INSTALL_CAVESTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_CAVESTACK_DIR="$(cd "$(dirname "$0")" && pwd -P)"
INSTALL_SKILLS_DIR="$(dirname "$INSTALL_CAVESTACK_DIR")"
BROWSE_BIN="$SOURCE_CAVESTACK_DIR/browse/dist/browse"
CODEX_SKILLS="$HOME/.codex/skills"
CODEX_CAVESTACK="$CODEX_SKILLS/cavestack"
FACTORY_SKILLS="$HOME/.factory/skills"
FACTORY_CAVESTACK="$FACTORY_SKILLS/cavestack"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── Quiet mode helper ────────────────────────────────────────
QUIET=0
log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }

# ─── Parse flags ──────────────────────────────────────────────
HOST="claude"
LOCAL_INSTALL=0
SKILL_PREFIX=1
SKILL_PREFIX_FLAG=0
TEAM_MODE=0
NO_TEAM_MODE=0
CAVEMAN_INSTALL=1
NO_CAVEMAN=0
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "Missing value for --host (expected claude, codex, kiro, or auto)" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --local) LOCAL_INSTALL=1; shift ;;
    --prefix)    SKILL_PREFIX=1; SKILL_PREFIX_FLAG=1; shift ;;
    --no-prefix) SKILL_PREFIX=0; SKILL_PREFIX_FLAG=1; shift ;;
    --team)    TEAM_MODE=1; shift ;;
    --no-team) NO_TEAM_MODE=1; shift ;;
    --caveman)    CAVEMAN_INSTALL=1; NO_CAVEMAN=0; shift ;;
    --no-caveman) CAVEMAN_INSTALL=0; NO_CAVEMAN=1; shift ;;
    -q|--quiet) QUIET=1; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|kiro|factory|auto) ;;
  openclaw)
    echo ""
    echo "OpenClaw integration uses a different model — OpenClaw spawns Claude Code"
    echo "sessions natively via ACP. cavestack provides methodology artifacts, not a"
    echo "full skill installation."
    echo ""
    echo "To integrate cavestack with OpenClaw:"
    echo "  1. Tell your OpenClaw agent: 'install cavestack for openclaw'"
    echo "  2. Or generate artifacts: bun run gen:skill-docs --host openclaw"
    echo "  3. See docs/OPENCLAW.md for the full architecture"
    echo ""
    exit 0 ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, kiro, factory, openclaw, or auto)" >&2; exit 1 ;;
esac

# ─── Resolve skill prefix preference ─────────────────────────
# Priority: CLI flag > saved config > interactive prompt (or flat default for non-TTY)
CAVESTACK_CONFIG="$SOURCE_CAVESTACK_DIR/bin/cavestack-config"
export CAVESTACK_SETUP_RUNNING=1  # Prevent cavestack-config post-set hook from triggering relink mid-setup
if [ "$SKILL_PREFIX_FLAG" -eq 0 ]; then
  _saved_prefix="$("$CAVESTACK_CONFIG" get skill_prefix 2>/dev/null || true)"
  if [ "$_saved_prefix" = "true" ]; then
    SKILL_PREFIX=1
  elif [ "$_saved_prefix" = "false" ]; then
    SKILL_PREFIX=0
  else
    # No saved preference — prompt interactively (or default flat for non-TTY/quiet)
    if [ "$QUIET" -eq 1 ]; then
      SKILL_PREFIX=0
    elif [ -t 0 ]; then
      echo ""
      echo "Skill naming: how should cavestack skills appear?"
      echo ""
      echo "  1) Short names: /qa, /ship, /review"
      echo "     Recommended. Clean and fast to type."
      echo ""
      echo "  2) Namespaced: /cavestack-qa, /cavestack-ship, /cavestack-review"
      echo "     Use this if you run other skill packs alongside cavestack to avoid conflicts."
      echo ""
      printf "Choice [1/2] (default: 1, auto-selects in 10s): "
      read -t 10 -r _prefix_choice </dev/tty 2>/dev/null || _prefix_choice=""
      case "$_prefix_choice" in
        2) SKILL_PREFIX=1 ;;
        *) SKILL_PREFIX=0 ;;
      esac
    else
      SKILL_PREFIX=0
    fi
    # Save the choice for future runs
    "$CAVESTACK_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
  fi
else
  # Flag was passed explicitly — persist the choice
  "$CAVESTACK_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
fi

# --local: install to .claude/skills/ in the current working directory (deprecated)
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  echo "Warning: --local is deprecated. Use global install + --team instead." >&2
  echo "  See: https://github.com/JerkyJesse/cavestack#team-mode" >&2
  if [ "$HOST" = "codex" ]; then
    echo "Error: --local is only supported for Claude Code (not Codex)." >&2
    exit 1
  fi
  INSTALL_SKILLS_DIR="$(pwd)/.claude/skills"
  mkdir -p "$INSTALL_SKILLS_DIR"
  HOST="claude"
  INSTALL_CODEX=0
fi

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_KIRO=0
INSTALL_FACTORY=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v kiro-cli >/dev/null 2>&1 && INSTALL_KIRO=1
  command -v droid >/dev/null 2>&1 && INSTALL_FACTORY=1
  # If none found, default to claude
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_KIRO" -eq 0 ] && [ "$INSTALL_FACTORY" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "kiro" ]; then
  INSTALL_KIRO=1
elif [ "$HOST" = "factory" ]; then
  INSTALL_FACTORY=1
fi

migrate_direct_codex_install() {
  local cavestack_dir="$1"
  local codex_cavestack="$2"
  local migrated_dir="$HOME/.cavestack/repos/cavestack"

  [ "$cavestack_dir" = "$codex_cavestack" ] || return 0
  [ -L "$cavestack_dir" ] && return 0

  mkdir -p "$(dirname "$migrated_dir")"
  if [ -e "$migrated_dir" ] && [ "$migrated_dir" != "$cavestack_dir" ]; then
    echo "cavestack setup failed: direct Codex install detected at $cavestack_dir" >&2
    echo "A migrated repo already exists at $migrated_dir; move one of them aside and rerun setup." >&2
    exit 1
  fi

  log "Migrating direct Codex install to $migrated_dir to avoid duplicate skill discovery..."
  mv "$cavestack_dir" "$migrated_dir"
  SOURCE_CAVESTACK_DIR="$migrated_dir"
  INSTALL_CAVESTACK_DIR="$migrated_dir"
  INSTALL_SKILLS_DIR="$(dirname "$INSTALL_CAVESTACK_DIR")"
  BROWSE_BIN="$SOURCE_CAVESTACK_DIR/browse/dist/browse"
}

if [ "$INSTALL_CODEX" -eq 1 ]; then
  migrate_direct_codex_install "$SOURCE_CAVESTACK_DIR" "$CODEX_CAVESTACK"
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Bun can't launch Chromium due to broken pipe handling
    # (oven-sh/bun#4253). Use Node.js to verify Chromium works instead.
    (
      cd "$SOURCE_CAVESTACK_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$SOURCE_CAVESTACK_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_CAVESTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SOURCE_CAVESTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SOURCE_CAVESTACK_DIR/bun.lock" ] && [ "$SOURCE_CAVESTACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  log "Building browse binary..."
  (
    cd "$SOURCE_CAVESTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$SOURCE_CAVESTACK_DIR/browse/dist/.version" ]; then
    git -C "$SOURCE_CAVESTACK_DIR" rev-parse HEAD > "$SOURCE_CAVESTACK_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "cavestack setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 1b. Generate .agents/ Codex skill docs — always regenerate to prevent stale descriptions.
# .agents/ is no longer committed — generated at setup time from .tmpl templates.
# bun run build already does this, but we need it when NEEDS_BUILD=0 (binary is fresh).
# Always regenerate: generation is fast (<2s) and mtime-based staleness checks are fragile
# (miss stale files when timestamps match after clone/checkout/upgrade).
AGENTS_DIR="$SOURCE_CAVESTACK_DIR/.agents/skills"
NEEDS_AGENTS_GEN=1

if [ "$NEEDS_AGENTS_GEN" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating .agents/ skill docs..."
  (
    cd "$SOURCE_CAVESTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host codex
  )
fi

# 1c. Generate .factory/ Factory Droid skill docs
if [ "$INSTALL_FACTORY" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating .factory/ skill docs..."
  (
    cd "$SOURCE_CAVESTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host factory
  )
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$SOURCE_CAVESTACK_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Node.js launches Chromium (not Bun — see oven-sh/bun#4253).
    # Ensure playwright is importable by Node from the cavestack directory.
    if ! command -v node >/dev/null 2>&1; then
      echo "cavestack setup failed: Node.js is required on Windows (Bun cannot launch Chromium due to a pipe bug)" >&2
      echo "  Install Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "Windows detected — verifying Node.js can load Playwright..."
    (
      cd "$SOURCE_CAVESTACK_DIR"
      # Bun's node_modules already has playwright; verify Node can require it
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "cavestack setup failed: Playwright Chromium could not be launched via Node.js" >&2
    echo "  This is a known issue with Bun on Windows (oven-sh/bun#4253)." >&2
    echo "  Ensure Node.js is installed and 'node -e \"require('playwright')\"' works." >&2
  else
    echo "cavestack setup failed: Playwright Chromium could not be launched" >&2
  fi
  exit 1
fi

# 3. Ensure ~/.cavestack global state directory exists
mkdir -p "$HOME/.cavestack/projects"

# ─── Helper: link Claude skill subdirectories into a skills parent directory ──
# Creates real directories (not symlinks) at the top level with a SKILL.md symlink
# inside. This ensures Claude discovers them as top-level skills, not nested under
# cavestack/ (which would auto-prefix them as cavestack-*).
# When SKILL_PREFIX=1, directories are prefixed with "cavestack-".
# Use --no-prefix to restore flat names.
link_claude_skill_dirs() {
  local cavestack_dir="$1"
  local skills_dir="$2"
  local linked=()
  for skill_dir in "$cavestack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      dir_name="$(basename "$skill_dir")"
      # Skip node_modules
      [ "$dir_name" = "node_modules" ] && continue
      # Use frontmatter name: if present (e.g., run-tests/ with name: test → symlink as "test")
      skill_name=$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
      [ -z "$skill_name" ] && skill_name="$dir_name"
      # Apply cavestack- prefix unless --no-prefix or already prefixed
      if [ "$SKILL_PREFIX" -eq 1 ]; then
        case "$skill_name" in
          cavestack-*) link_name="$skill_name" ;;
          *)        link_name="cavestack-$skill_name" ;;
        esac
      else
        link_name="$skill_name"
      fi
      target="$skills_dir/$link_name"
      # Upgrade old directory symlinks to real directories
      if [ -L "$target" ]; then
        rm -f "$target"
      fi
      # Create real directory with symlinked SKILL.md (absolute path)
      # Use mkdir -p unconditionally (idempotent) to avoid TOCTOU race
      mkdir -p "$target"
      # Validate target isn't a symlink before creating the link
      if [ -L "$target/SKILL.md" ]; then rm "$target/SKILL.md"; fi
      ln -snf "$cavestack_dir/$dir_name/SKILL.md" "$target/SKILL.md"
      linked+=("$link_name")
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: remove old unprefixed Claude skill entries ───────────────────────
# Migration: when switching from flat names to cavestack- prefixed names,
# clean up stale symlinks or directories that point into the cavestack directory.
cleanup_old_claude_symlinks() {
  local cavestack_dir="$1"
  local skills_dir="$2"
  local removed=()
  for skill_dir in "$cavestack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      # Skip already-prefixed dirs (cavestack-upgrade) — no old symlink to clean
      case "$skill_name" in cavestack-*) continue ;; esac
      old_target="$skills_dir/$skill_name"
      # Remove directory symlinks pointing into cavestack/
      if [ -L "$old_target" ]; then
        link_dest="$(readlink "$old_target" 2>/dev/null || true)"
        case "$link_dest" in
          cavestack/*|*/cavestack/*)
            rm -f "$old_target"
            removed+=("$skill_name")
            ;;
        esac
      # Remove real directories with symlinked SKILL.md pointing into cavestack/
      elif [ -d "$old_target" ] && [ -L "$old_target/SKILL.md" ]; then
        link_dest="$(readlink "$old_target/SKILL.md" 2>/dev/null || true)"
        case "$link_dest" in
          *cavestack*)
            rm -rf "$old_target"
            removed+=("$skill_name")
            ;;
        esac
      fi
    fi
  done
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up old entries: ${removed[*]}"
  fi
}

# ─── Helper: remove old prefixed Claude skill entries ─────────────────────────
# Reverse migration: when switching from cavestack- prefixed names to flat names,
# clean up stale cavestack-* symlinks or directories that point into the cavestack directory.
cleanup_prefixed_claude_symlinks() {
  local cavestack_dir="$1"
  local skills_dir="$2"
  local removed=()
  for skill_dir in "$cavestack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      # Only clean up prefixed entries for dirs that AREN'T already prefixed
      # (e.g., remove cavestack-qa but NOT cavestack-upgrade which is the real dir name)
      case "$skill_name" in cavestack-*) continue ;; esac
      prefixed_target="$skills_dir/cavestack-$skill_name"
      # Remove directory symlinks pointing into cavestack/
      if [ -L "$prefixed_target" ]; then
        link_dest="$(readlink "$prefixed_target" 2>/dev/null || true)"
        case "$link_dest" in
          cavestack/*|*/cavestack/*)
            rm -f "$prefixed_target"
            removed+=("cavestack-$skill_name")
            ;;
        esac
      # Remove real directories with symlinked SKILL.md pointing into cavestack/
      elif [ -d "$prefixed_target" ] && [ -L "$prefixed_target/SKILL.md" ]; then
        link_dest="$(readlink "$prefixed_target/SKILL.md" 2>/dev/null || true)"
        case "$link_dest" in
          *cavestack*)
            rm -rf "$prefixed_target"
            removed+=("cavestack-$skill_name")
            ;;
        esac
      fi
    fi
  done
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up prefixed entries: ${removed[*]}"
  fi
}

# ─── Helper: link generated Codex skills into a skills parent directory ──
# Installs from .agents/skills/cavestack-* (the generated Codex-format skills)
# instead of source dirs (which have Claude paths).
link_codex_skill_dirs() {
  local cavestack_dir="$1"
  local skills_dir="$2"
  local agents_dir="$cavestack_dir/.agents/skills"
  local linked=()

  if [ ! -d "$agents_dir" ]; then
    echo "  Generating .agents/ skill docs..."
    ( cd "$cavestack_dir" && bun run gen:skill-docs --host codex )
  fi

  if [ ! -d "$agents_dir" ]; then
    echo "  warning: .agents/skills/ generation failed — run 'bun run gen:skill-docs --host codex' manually" >&2
    return 1
  fi

  for skill_dir in "$agents_dir"/cavestack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip the sidecar directory — it contains runtime asset symlinks (bin/,
      # browse/), not a skill. Linking it would overwrite the root cavestack
      # symlink that Step 5 already pointed at the repo root.
      [ "$skill_name" = "cavestack" ] && continue
      target="$skills_dir/$skill_name"
      # Create or update symlink
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: create .agents/skills/cavestack/ sidecar symlinks ──────────
# Codex/Gemini/Cursor read skills from .agents/skills/. We link runtime
# assets (bin/, browse/dist/, review/, qa/, etc.) so skill templates can
# resolve paths like $SKILL_ROOT/review/design-checklist.md.
create_agents_sidecar() {
  local repo_root="$1"
  local agents_cavestack="$repo_root/.agents/skills/cavestack"
  mkdir -p "$agents_cavestack"

  # Sidecar directories that skills reference at runtime
  for asset in bin browse review qa; do
    local src="$SOURCE_CAVESTACK_DIR/$asset"
    local dst="$agents_cavestack/$asset"
    if [ -d "$src" ] || [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done

  # Sidecar files that skills reference at runtime
  for file in ETHOS.md; do
    local src="$SOURCE_CAVESTACK_DIR/$file"
    local dst="$agents_cavestack/$file"
    if [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done
}

# ─── Helper: create a minimal ~/.codex/skills/cavestack runtime root ───────────
# Codex scans ~/.codex/skills recursively. Exposing the whole repo here causes
# duplicate skills because source SKILL.md files and generated Codex skills are
# both discoverable. Keep this directory limited to runtime assets + root skill.
create_codex_runtime_root() {
  local cavestack_dir="$1"
  local codex_cavestack="$2"
  local agents_dir="$cavestack_dir/.agents/skills"

  if [ -L "$codex_cavestack" ]; then
    rm -f "$codex_cavestack"
  elif [ -d "$codex_cavestack" ] && [ "$codex_cavestack" != "$cavestack_dir" ]; then
    # Old direct installs left a real directory here with stale source skills.
    # Remove it so we start fresh with only the minimal runtime assets.
    rm -rf "$codex_cavestack"
  fi

  mkdir -p "$codex_cavestack" "$codex_cavestack/browse" "$codex_cavestack/cavestack-upgrade" "$codex_cavestack/review"

  if [ -f "$agents_dir/cavestack/SKILL.md" ]; then
    ln -snf "$agents_dir/cavestack/SKILL.md" "$codex_cavestack/SKILL.md"
  fi
  if [ -d "$cavestack_dir/bin" ]; then
    ln -snf "$cavestack_dir/bin" "$codex_cavestack/bin"
  fi
  if [ -d "$cavestack_dir/browse/dist" ]; then
    ln -snf "$cavestack_dir/browse/dist" "$codex_cavestack/browse/dist"
  fi
  if [ -d "$cavestack_dir/browse/bin" ]; then
    ln -snf "$cavestack_dir/browse/bin" "$codex_cavestack/browse/bin"
  fi
  if [ -f "$agents_dir/cavestack-upgrade/SKILL.md" ]; then
    ln -snf "$agents_dir/cavestack-upgrade/SKILL.md" "$codex_cavestack/cavestack-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, NOT the whole review/ dir which has SKILL.md)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$cavestack_dir/review/$f" ]; then
      ln -snf "$cavestack_dir/review/$f" "$codex_cavestack/review/$f"
    fi
  done
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$cavestack_dir/ETHOS.md" ]; then
    ln -snf "$cavestack_dir/ETHOS.md" "$codex_cavestack/ETHOS.md"
  fi
}

create_factory_runtime_root() {
  local cavestack_dir="$1"
  local factory_cavestack="$2"
  local factory_dir="$cavestack_dir/.factory/skills"

  if [ -L "$factory_cavestack" ]; then
    rm -f "$factory_cavestack"
  elif [ -d "$factory_cavestack" ] && [ "$factory_cavestack" != "$cavestack_dir" ]; then
    rm -rf "$factory_cavestack"
  fi

  mkdir -p "$factory_cavestack" "$factory_cavestack/browse" "$factory_cavestack/cavestack-upgrade" "$factory_cavestack/review"

  if [ -f "$factory_dir/cavestack/SKILL.md" ]; then
    ln -snf "$factory_dir/cavestack/SKILL.md" "$factory_cavestack/SKILL.md"
  fi
  if [ -d "$cavestack_dir/bin" ]; then
    ln -snf "$cavestack_dir/bin" "$factory_cavestack/bin"
  fi
  if [ -d "$cavestack_dir/browse/dist" ]; then
    ln -snf "$cavestack_dir/browse/dist" "$factory_cavestack/browse/dist"
  fi
  if [ -d "$cavestack_dir/browse/bin" ]; then
    ln -snf "$cavestack_dir/browse/bin" "$factory_cavestack/browse/bin"
  fi
  if [ -f "$factory_dir/cavestack-upgrade/SKILL.md" ]; then
    ln -snf "$factory_dir/cavestack-upgrade/SKILL.md" "$factory_cavestack/cavestack-upgrade/SKILL.md"
  fi
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$cavestack_dir/review/$f" ]; then
      ln -snf "$cavestack_dir/review/$f" "$factory_cavestack/review/$f"
    fi
  done
  if [ -f "$cavestack_dir/ETHOS.md" ]; then
    ln -snf "$cavestack_dir/ETHOS.md" "$factory_cavestack/ETHOS.md"
  fi
}

link_factory_skill_dirs() {
  local cavestack_dir="$1"
  local skills_dir="$2"
  local factory_dir="$cavestack_dir/.factory/skills"
  local linked=()

  if [ ! -d "$factory_dir" ]; then
    echo "  Generating .factory/ skill docs..."
    ( cd "$cavestack_dir" && bun run gen:skill-docs --host factory )
  fi

  if [ ! -d "$factory_dir" ]; then
    echo "  warning: .factory/skills/ generation failed — run 'bun run gen:skill-docs --host factory' manually" >&2
    return 1
  fi

  for skill_dir in "$factory_dir"/cavestack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "cavestack" ] && continue
      target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# 4. Install for Claude (default)
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"
SKILLS_PARENT_BASENAME="$(basename "$(dirname "$INSTALL_SKILLS_DIR")")"
CODEX_REPO_LOCAL=0
if [ "$SKILLS_BASENAME" = "skills" ] && [ "$SKILLS_PARENT_BASENAME" = ".agents" ]; then
  CODEX_REPO_LOCAL=1
fi

if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    # Clean up stale symlinks from the opposite prefix mode
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      cleanup_old_claude_symlinks "$SOURCE_CAVESTACK_DIR" "$INSTALL_SKILLS_DIR"
    else
      cleanup_prefixed_claude_symlinks "$SOURCE_CAVESTACK_DIR" "$INSTALL_SKILLS_DIR"
    fi
    # Patch name: fields BEFORE creating symlinks so link_claude_skill_dirs
    # reads the correct (patched) name: values for symlink naming
    "$SOURCE_CAVESTACK_DIR/bin/cavestack-patch-names" "$SOURCE_CAVESTACK_DIR" "$SKILL_PREFIX"
    link_claude_skill_dirs "$SOURCE_CAVESTACK_DIR" "$INSTALL_SKILLS_DIR"
    # Self-healing: re-run cavestack-relink to ensure name: fields and directory
    # names are consistent with the config. This catches cases where an interrupted
    # setup, stale git state, or gen:skill-docs left name: fields out of sync.
    CAVESTACK_RELINK="$SOURCE_CAVESTACK_DIR/bin/cavestack-relink"
    if [ -x "$CAVESTACK_RELINK" ]; then
      CAVESTACK_SKILLS_DIR="$INSTALL_SKILLS_DIR" CAVESTACK_INSTALL_DIR="$SOURCE_CAVESTACK_DIR" "$CAVESTACK_RELINK" >/dev/null 2>&1 || true
    fi
    # Backwards-compat alias: /connect-chrome → /open-cavestack-browser
    _OGB_LINK="$INSTALL_SKILLS_DIR/connect-chrome"
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      _OGB_LINK="$INSTALL_SKILLS_DIR/cavestack-connect-chrome"
    fi
    if [ -L "$_OGB_LINK" ] || [ ! -e "$_OGB_LINK" ]; then
      ln -snf "cavestack/open-cavestack-browser" "$_OGB_LINK"
    fi
    if [ "$LOCAL_INSTALL" -eq 1 ]; then
      log "cavestack ready (project-local)."
      log "  skills: $INSTALL_SKILLS_DIR"
    else
      log "cavestack ready (claude)."
    fi
    log "  browse: $BROWSE_BIN"
  else
    # Not inside a skills/ directory — symlink into ~/.claude/skills/ and retry
    CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
    CLAUDE_CAVESTACK_LINK="$CLAUDE_SKILLS_DIR/cavestack"
    mkdir -p "$CLAUDE_SKILLS_DIR"
    ln -snf "$SOURCE_CAVESTACK_DIR" "$CLAUDE_CAVESTACK_LINK"
    log "  symlinked $CLAUDE_CAVESTACK_LINK -> $SOURCE_CAVESTACK_DIR"
    INSTALL_SKILLS_DIR="$CLAUDE_SKILLS_DIR"
    INSTALL_CAVESTACK_DIR="$CLAUDE_CAVESTACK_LINK"
    # Clean up stale symlinks from the opposite prefix mode
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      cleanup_old_claude_symlinks "$SOURCE_CAVESTACK_DIR" "$INSTALL_SKILLS_DIR"
    else
      cleanup_prefixed_claude_symlinks "$SOURCE_CAVESTACK_DIR" "$INSTALL_SKILLS_DIR"
    fi
    "$SOURCE_CAVESTACK_DIR/bin/cavestack-patch-names" "$SOURCE_CAVESTACK_DIR" "$SKILL_PREFIX"
    link_claude_skill_dirs "$SOURCE_CAVESTACK_DIR" "$INSTALL_SKILLS_DIR"
    CAVESTACK_RELINK="$SOURCE_CAVESTACK_DIR/bin/cavestack-relink"
    if [ -x "$CAVESTACK_RELINK" ]; then
      CAVESTACK_SKILLS_DIR="$INSTALL_SKILLS_DIR" CAVESTACK_INSTALL_DIR="$SOURCE_CAVESTACK_DIR" "$CAVESTACK_RELINK" >/dev/null 2>&1 || true
    fi
    _OGB_LINK="$INSTALL_SKILLS_DIR/connect-chrome"
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      _OGB_LINK="$INSTALL_SKILLS_DIR/cavestack-connect-chrome"
    fi
    if [ -L "$_OGB_LINK" ] || [ ! -e "$_OGB_LINK" ]; then
      ln -snf "cavestack/open-cavestack-browser" "$_OGB_LINK"
    fi
    log "cavestack ready (claude)."
    log "  browse: $BROWSE_BIN"
  fi
fi

# 5. Install for Codex
if [ "$INSTALL_CODEX" -eq 1 ]; then
  if [ "$CODEX_REPO_LOCAL" -eq 1 ]; then
    CODEX_SKILLS="$INSTALL_SKILLS_DIR"
    CODEX_CAVESTACK="$INSTALL_CAVESTACK_DIR"
  fi
  mkdir -p "$CODEX_SKILLS"

  # Skip runtime root creation for repo-local installs — the checkout IS the runtime root.
  # create_codex_runtime_root would create self-referential symlinks (bin → bin, etc.).
  if [ "$CODEX_REPO_LOCAL" -eq 0 ]; then
    create_codex_runtime_root "$SOURCE_CAVESTACK_DIR" "$CODEX_CAVESTACK"
  fi
  # Install generated Codex-format skills (not Claude source dirs)
  link_codex_skill_dirs "$SOURCE_CAVESTACK_DIR" "$CODEX_SKILLS"

  log "cavestack ready (codex)."
  log "  browse: $BROWSE_BIN"
  log "  codex skills: $CODEX_SKILLS"
fi

# 6. Install for Kiro CLI (copy from .agents/skills, rewrite paths)
if [ "$INSTALL_KIRO" -eq 1 ]; then
  KIRO_SKILLS="$HOME/.kiro/skills"
  AGENTS_DIR="$SOURCE_CAVESTACK_DIR/.agents/skills"
  mkdir -p "$KIRO_SKILLS"

  # Create cavestack dir with symlinks for runtime assets, copy+sed for SKILL.md
  KIRO_CAVESTACK="$KIRO_SKILLS/cavestack"
  # Remove old whole-dir symlink from previous installs
  [ -L "$KIRO_CAVESTACK" ] && rm -f "$KIRO_CAVESTACK"
  mkdir -p "$KIRO_CAVESTACK" "$KIRO_CAVESTACK/browse" "$KIRO_CAVESTACK/cavestack-upgrade" "$KIRO_CAVESTACK/review"
  ln -snf "$SOURCE_CAVESTACK_DIR/bin" "$KIRO_CAVESTACK/bin"
  ln -snf "$SOURCE_CAVESTACK_DIR/browse/dist" "$KIRO_CAVESTACK/browse/dist"
  ln -snf "$SOURCE_CAVESTACK_DIR/browse/bin" "$KIRO_CAVESTACK/browse/bin"
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$SOURCE_CAVESTACK_DIR/ETHOS.md" ]; then
    ln -snf "$SOURCE_CAVESTACK_DIR/ETHOS.md" "$KIRO_CAVESTACK/ETHOS.md"
  fi
  # cavestack-upgrade skill
  if [ -f "$AGENTS_DIR/cavestack-upgrade/SKILL.md" ]; then
    ln -snf "$AGENTS_DIR/cavestack-upgrade/SKILL.md" "$KIRO_CAVESTACK/cavestack-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, not whole dir)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$SOURCE_CAVESTACK_DIR/review/$f" ]; then
      ln -snf "$SOURCE_CAVESTACK_DIR/review/$f" "$KIRO_CAVESTACK/review/$f"
    fi
  done

  # Rewrite root SKILL.md paths for Kiro
  sed -e "s|~/.claude/skills/cavestack|~/.kiro/skills/cavestack|g" \
      -e "s|\.claude/skills/cavestack|.kiro/skills/cavestack|g" \
      -e "s|\.claude/skills|.kiro/skills|g" \
      "$SOURCE_CAVESTACK_DIR/SKILL.md" > "$KIRO_CAVESTACK/SKILL.md"

  if [ ! -d "$AGENTS_DIR" ]; then
    echo "  warning: no .agents/skills/ directory found — run 'bun run build' first" >&2
  else
    for skill_dir in "$AGENTS_DIR"/cavestack*/; do
      [ -f "$skill_dir/SKILL.md" ] || continue
      skill_name="$(basename "$skill_dir")"
      target_dir="$KIRO_SKILLS/$skill_name"
      mkdir -p "$target_dir"
      # Generated Codex skills use $HOME/.codex (not ~/), plus $CAVESTACK_ROOT variables.
      # Rewrite the default CAVESTACK_ROOT value and any remaining literal paths.
      sed -e 's|\$HOME/.codex/skills/cavestack|$HOME/.kiro/skills/cavestack|g' \
          -e "s|~/.codex/skills/cavestack|~/.kiro/skills/cavestack|g" \
          -e "s|~/.claude/skills/cavestack|~/.kiro/skills/cavestack|g" \
          "$skill_dir/SKILL.md" > "$target_dir/SKILL.md"
    done
    echo "cavestack ready (kiro)."
    echo "  browse: $BROWSE_BIN"
    echo "  kiro skills: $KIRO_SKILLS"
  fi
fi

# 6b. Install for Factory Droid
if [ "$INSTALL_FACTORY" -eq 1 ]; then
  mkdir -p "$FACTORY_SKILLS"
  create_factory_runtime_root "$SOURCE_CAVESTACK_DIR" "$FACTORY_CAVESTACK"
  link_factory_skill_dirs "$SOURCE_CAVESTACK_DIR" "$FACTORY_SKILLS"
  echo "cavestack ready (factory)."
  echo "  browse: $BROWSE_BIN"
  echo "  factory skills: $FACTORY_SKILLS"
fi

# 7. Create .agents/ sidecar symlinks for the real Codex skill target.
# The root Codex skill ends up pointing at $SOURCE_CAVESTACK_DIR/.agents/skills/cavestack,
# so the runtime assets must live there for both global and repo-local installs.
if [ "$INSTALL_CODEX" -eq 1 ]; then
  create_agents_sidecar "$SOURCE_CAVESTACK_DIR"
fi

# 8. Run pending version migrations
# Migrations handle state fixes that ./setup alone can't cover (stale config,
# orphaned files, directory structure changes). Each migration is idempotent.
MIGRATIONS_DIR="$SOURCE_CAVESTACK_DIR/cavestack-upgrade/migrations"
CURRENT_VERSION=$(cat "$SOURCE_CAVESTACK_DIR/VERSION" 2>/dev/null || echo "unknown")
LAST_SETUP_VERSION=$(cat "$HOME/.cavestack/.last-setup-version" 2>/dev/null || echo "0.0.0.0")
if [ -d "$MIGRATIONS_DIR" ] && [ "$CURRENT_VERSION" != "unknown" ] && [ "$LAST_SETUP_VERSION" != "$CURRENT_VERSION" ]; then
  # Fresh install (no marker file) — skip migrations, just write marker
  if [ ! -f "$HOME/.cavestack/.last-setup-version" ]; then
    : # fall through to marker write below
  else
    find "$MIGRATIONS_DIR" -maxdepth 1 -name 'v*.sh' -type f 2>/dev/null | sort -V | while IFS= read -r migration; do
      m_ver="$(basename "$migration" .sh | sed 's/^v//')"
      # Run if migration is newer than last setup version AND not newer than current version
      if [ "$(printf '%s\n%s' "$LAST_SETUP_VERSION" "$m_ver" | sort -V | head -1)" = "$LAST_SETUP_VERSION" ] && [ "$LAST_SETUP_VERSION" != "$m_ver" ] \
         && [ "$(printf '%s\n%s' "$m_ver" "$CURRENT_VERSION" | sort -V | tail -1)" = "$CURRENT_VERSION" ]; then
        echo "  running migration $m_ver..."
        bash "$migration" || echo "  warning: migration $m_ver had errors (non-fatal)"
      fi
    done
  fi
fi
mkdir -p "$HOME/.cavestack"
if [ "$CURRENT_VERSION" != "unknown" ]; then
  echo "$CURRENT_VERSION" > "$HOME/.cavestack/.last-setup-version"
fi

# 9. First-time welcome + legacy cleanup
if [ ! -f "$HOME/.cavestack/.welcome-seen" ]; then
  log "  Welcome! Run /cavestack-upgrade anytime to stay current."
  touch "$HOME/.cavestack/.welcome-seen"
fi
rm -f /tmp/cavestack-latest-version

# 10. Team mode: register/unregister SessionStart hook
SETTINGS_HOOK="$SOURCE_CAVESTACK_DIR/bin/cavestack-settings-hook"
HOOK_CMD="$SOURCE_CAVESTACK_DIR/bin/cavestack-session-update"

if [ "$TEAM_MODE" -eq 1 ]; then
  "$CAVESTACK_CONFIG" set auto_upgrade true 2>/dev/null || true
  "$CAVESTACK_CONFIG" set team_mode true 2>/dev/null || true

  # Register SessionStart hook in Claude Code settings
  if [ -x "$SETTINGS_HOOK" ]; then
    "$SETTINGS_HOOK" add "$HOOK_CMD" 2>/dev/null || true
  fi

  log ""
  log "Team mode enabled: cavestack will auto-update at the start of each Claude Code session."
  log "  Hook: $HOOK_CMD"
  log "  To disable: ./setup --no-team"
  log ""
  log "Bootstrap your repo:"
  log "  cd <your-repo> && $SOURCE_CAVESTACK_DIR/bin/cavestack-team-init required"
fi

if [ "$NO_TEAM_MODE" -eq 1 ]; then
  "$CAVESTACK_CONFIG" set auto_upgrade false 2>/dev/null || true
  "$CAVESTACK_CONFIG" set team_mode false 2>/dev/null || true

  # Remove SessionStart hook from Claude Code settings
  if [ -x "$SETTINGS_HOOK" ]; then
    "$SETTINGS_HOOK" remove "$HOOK_CMD" 2>/dev/null || true
  fi

  log "Team mode disabled: auto-update hook removed."
fi

# 11. Caveman always-on mode: register SessionStart + UserPromptSubmit hooks
#     (opt out with --no-caveman)
if [ "$CAVEMAN_INSTALL" -eq 1 ] && [ "$NO_CAVEMAN" -eq 0 ]; then
  if [ -x "$SETTINGS_HOOK" ]; then
    if command -v node >/dev/null 2>&1; then
      "$SETTINGS_HOOK" install-caveman 2>/dev/null && \
        log "Caveman always-on registered: terse mode activates on every session start." || \
        log "Caveman registration failed (non-fatal)."
      log "  Toggle per session: /caveman lite | /caveman full | /caveman ultra | stop caveman"
      log "  Uninstall: $SETTINGS_HOOK remove-caveman"
    else
      log "Skipped caveman hook registration: Node.js not found (install from https://nodejs.org/)."
      log "After installing Node.js, run: $SETTINGS_HOOK install-caveman"
    fi
  fi
fi

if [ "$NO_CAVEMAN" -eq 1 ]; then
  if [ -x "$SETTINGS_HOOK" ]; then
    "$SETTINGS_HOOK" remove-caveman 2>/dev/null || true
    log "Caveman hooks removed from Claude Code settings."
  fi
fi
